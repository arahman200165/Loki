{
  "name": "loki",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "server:check": "npm run check --workspace=server",
    "server:dev": "npm run dev --workspace=server",
    "server:migrate": "npm run migrate --workspace=server",
    "server:start": "npm run start --workspace=server",
    "mobile:lint": "npm run lint --workspace=mobile",
    "mobile:start": "npm run start --workspace=mobile",
    "shared:typecheck": "npm run typecheck --workspace=@loki/shared",
    "smoke:backend": "node qa/smoke-backend.mjs"
  }
}
